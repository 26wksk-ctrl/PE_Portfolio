rules_version = '2';

// 자기주도 체육탐구 포트폴리오 - Firestore 보안 규칙 (구글 로그인 적용 버전)
//
// 변경 요지:
//   - 모든 쓰기는 "로그인한 사용자"만 가능하고, 학생은 자기 uid 의 문서만 만들 수 있음
//   - 학생은 자기 문서만 읽고, 교사(허용 이메일)는 전체 읽기 가능
//   - 수정/삭제는 여전히 금지
//
// ★ 아래 isTeacher() 의 이메일 목록은 js/config.js 의 TEACHER_EMAILS 와 동일해야 합니다.

service cloud.firestore {
  match /databases/{database}/documents {

    // 사이트 활성/비활성 전역 스위치 (app_config/site)
    //   - 읽기: 누구나(로그인 전 학생 포함) 가능 — 화면을 켜고 끄기 위함
    //   - 쓰기: 비밀코드(클라이언트에서 확인) 또는 구글 교사 로그인으로 켜고 끔.
    //           둘 다 결국 active(불리언) + updated_at 두 필드만 쓰므로,
    //           쓰기는 "형식이 맞는 토글"만 허용한다. (데이터 손상 방지)
    match /app_config/{docId} {
      allow read: if true;
      allow write: if request.resource.data.keys().hasOnly(['active', 'updated_at'])
                   && request.resource.data.active is bool;
    }

    match /simple_responses/{docId} {
      // 교사: 전체 읽기 / 학생: 본인(uid) 문서만 읽기
      allow read: if isTeacher()
                  || (isSignedIn() && resource.data.student_id == request.auth.uid);

      // 생성: 로그인 + 본인 uid 로만 + 형식 검증
      allow create: if isSignedIn()
                    && request.resource.data.student_id == request.auth.uid
                    && isValidResponse(request.resource.data);

      allow update, delete: if false;
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}

function isSignedIn() {
  return request.auth != null;
}

// 교사 계정 이메일 목록 (config.js 의 TEACHER_EMAILS 와 일치시킬 것)
function isTeacher() {
  return isSignedIn()
         && request.auth.token.email_verified == true
         && request.auth.token.email in ['visionaryshl@gmail.com', 'simsy242424@gmail.com'];
}

function isValidResponse(data) {
  return data.keys().hasAll([
           'session_id', 'class_id', 'student_id', 'student_name',
           'activity_code', 'inquiry_question', 'next_try',
           'agency_score', 'sel_competency_code', 'submitted_at'
         ])
         && data.student_name is string && data.student_name.size() > 0 && data.student_name.size() <= 50
         && data.inquiry_question is string && data.inquiry_question.size() <= 1000
         && data.next_try is string && data.next_try.size() <= 1000
         && data.evidence_result is string && data.evidence_result.size() <= 2000
         && data.agency_score is int && data.agency_score >= 1 && data.agency_score <= 5;
}
