rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    match /app_config/site {
      allow read: if true;
      allow create, update: if isTeacher()
                            && request.resource.data.keys().hasOnly(['active', 'updated_at', 'updated_by'])
                            && request.resource.data.active is bool
                            && request.resource.data.updated_at == request.time
                            && request.resource.data.updated_by == request.auth.token.email;
      allow delete: if false;
    }

    match /app_config/lesson {
      allow read: if true;
      allow create, update: if isTeacher() && isValidLessonSettings();
      allow delete: if isTeacher();
    }

    match /app_config/share {
      allow read: if isSignedIn();
      allow create, update: if isTeacher()
                            && request.resource.data.keys().hasOnly(['by_class', 'updated_at', 'updated_by'])
                            && request.resource.data.by_class is map
                            && request.resource.data.updated_at == request.time
                            && request.resource.data.updated_by == request.auth.token.email;
      allow delete: if isTeacher();
    }

    match /app_config/{docId} {
      allow read, write: if false;
    }

    match /students/{uid} {
      allow read: if isTeacher() || (isSignedIn() && uid == request.auth.uid);
      allow create: if (isTeacher()
                        && request.resource.data.keys().hasOnly(teacherStudentKeys())
                        && isValidTeacherStudentFields())
                    || (isSignedIn()
                        && uid == request.auth.uid
                        && request.resource.data.keys().hasOnly(studentSelfKeys())
                        && isValidSelfClass());
      allow update: if (isTeacher()
                        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(teacherStudentKeys())
                        && isValidTeacherStudentFields())
                    || (isSignedIn()
                        && uid == request.auth.uid
                        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(studentSelfKeys())
                        && isValidSelfClass());
      allow delete: if isTeacher();
    }

    match /simple_responses/{docId} {
      allow read: if isTeacher()
                  || (isSignedIn() && resource.data.student_id == request.auth.uid);
      allow create: if isTeacher()
                    || (isSignedIn() && isStudentSubmissionOpen());
      allow update: if false;
      allow delete: if isTeacher();
    }

    match /trash_responses/{docId} {
      allow read, write: if isTeacher();
    }

    match /student_roster/{studentId} {
      allow get: if isTeacher() || canReadOwnRoster();
      allow list: if isTeacher() || canQueryOwnRosterByEmail();
      allow create: if isTeacher() && isValidRosterDoc(studentId);
      allow delete: if isTeacher();
      allow update: if (isTeacher() && isValidRosterDoc(studentId))
                    || canClaimOwnRoster(studentId);
    }

    match /users/{uid} {
      allow read: if isTeacher() || (isSignedIn() && uid == request.auth.uid);
      allow create: if isSignedIn()
                    && uid == request.auth.uid
                    && request.resource.data.uid == request.auth.uid
                    && request.resource.data.email == request.auth.token.email
                    && request.resource.data.role == 'student'
                    && request.resource.data.keys().hasOnly(['uid', 'email', 'role', 'studentId', 'createdAt'])
                    && request.resource.data.studentId is string
                    && request.resource.data.studentId.size() == 5
                    && request.resource.data.createdAt == request.time
                    && rosterAfterIsClaimedByAuth(request.resource.data.studentId);
      allow update: if false;
      allow delete: if isTeacher();
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}

function isSignedIn() {
  return request.auth != null;
}

function isTeacher() {
  return authHasEmail()
         && isEmailVerifiedOrUnknown()
         && request.auth.token.email in ['visionaryshl@gmail.com', 'simsy0924@gmail.com'];
}

function isEmailVerifiedOrUnknown() {
  return !('email_verified' in request.auth.token)
         || request.auth.token.email_verified == true;
}

function isStudentSubmissionOpen() {
  return isSiteActiveForStudentSubmission()
         && isLessonInputEnabledForStudentSubmission();
}

function isSiteActiveForStudentSubmission() {
  return exists(/databases/$(database)/documents/app_config/site)
         && get(/databases/$(database)/documents/app_config/site).data.active == true;
}

function isLessonInputEnabledForStudentSubmission() {
  return !exists(/databases/$(database)/documents/app_config/lesson)
         || !('inputEnabled' in get(/databases/$(database)/documents/app_config/lesson).data)
         || get(/databases/$(database)/documents/app_config/lesson).data.inputEnabled != false;
}

function authHasEmail() {
  return isSignedIn()
         && ('email' in request.auth.token)
         && request.auth.token.email is string
         && request.auth.token.email.size() > 0;
}

function authEmailLower() {
  return request.auth.token.email.lower();
}

function rosterEmailMatchesAuth() {
  return authHasEmail()
         && ('email' in resource.data)
         && resource.data.email is string
         && resource.data.email.size() > 0
         && resource.data.email == authEmailLower();
}

function rosterLinkedToAuth() {
  return isSignedIn()
         && ('linkedUid' in resource.data)
         && resource.data.linkedUid == request.auth.uid;
}

function rosterIsActive() {
  return !('status' in resource.data) || resource.data.status == 'active';
}

function canReadOwnRoster() {
  return rosterEmailMatchesAuth() || rosterLinkedToAuth();
}

function canQueryOwnRosterByEmail() {
  return rosterEmailMatchesAuth();
}

function canClaimOwnRoster(studentId) {
  return isSignedIn()
         && rosterIsActive()
         && rosterEmailMatchesAuth()
         && resource.data.isClaimed == false
         && (!('linkedUid' in resource.data) || resource.data.linkedUid == null || resource.data.linkedUid == '')
         && (!('linkedEmail' in resource.data) || resource.data.linkedEmail == null || resource.data.linkedEmail == '')
         && request.resource.data.isClaimed == true
         && request.resource.data.linkedUid == request.auth.uid
         && request.resource.data.linkedEmail == request.auth.token.email
         && request.resource.data.claimedAt == request.time
         && request.resource.data.diff(resource.data).affectedKeys()
              .hasOnly(['linkedUid', 'linkedEmail', 'isClaimed', 'claimedAt'])
         && userAfterPointsToRoster(studentId);
}

function rosterKeys() {
  return [
    'studentId', 'className', 'classNumber', 'studentNumber', 'name', 'displayName',
    'email', 'registrationCode', 'linkedUid', 'linkedEmail', 'isClaimed', 'claimedAt',
    'status', 'createdAt', 'createdBy', 'updatedAt', 'updatedBy'
  ];
}

function isValidRosterDoc(studentId) {
  return request.resource.data.keys().hasOnly(rosterKeys())
         && request.resource.data.keys().hasAll([
           'studentId', 'className', 'classNumber', 'studentNumber', 'name', 'displayName',
           'email', 'registrationCode', 'linkedUid', 'linkedEmail', 'isClaimed', 'claimedAt',
           'status', 'createdAt', 'createdBy'
         ])
         && request.resource.data.studentId == studentId
         && request.resource.data.studentId is string
         && request.resource.data.studentId.matches('^[0-9]{5}$')
         && isSafeText(request.resource.data.className, 30)
         && request.resource.data.classNumber is int
         && request.resource.data.classNumber >= 0
         && request.resource.data.classNumber <= 99
         && request.resource.data.studentNumber is int
         && request.resource.data.studentNumber >= 0
         && request.resource.data.studentNumber <= 99
         && isSafeText(request.resource.data.name, 30)
         && isSafeText(request.resource.data.displayName, 80)
         && isNullableEmail(request.resource.data.email)
         && isNullableSafeText(request.resource.data.registrationCode, 20)
         && request.resource.data.isClaimed is bool
         && request.resource.data.status in ['active', 'inactive']
         && request.resource.data.createdAt is timestamp
         && isEmailLike(request.resource.data.createdBy)
         && (!('updatedAt' in request.resource.data) || request.resource.data.updatedAt is timestamp)
         && (!('updatedBy' in request.resource.data) || isEmailLike(request.resource.data.updatedBy))
         && isValidRosterClaimState();
}

function isValidRosterClaimState() {
  return (request.resource.data.isClaimed == false
          && request.resource.data.linkedUid == null
          && request.resource.data.linkedEmail == null
          && request.resource.data.claimedAt == null)
         || (request.resource.data.isClaimed == true
             && isSafeText(request.resource.data.linkedUid, 128)
             && isEmailLike(request.resource.data.linkedEmail)
             && request.resource.data.claimedAt is timestamp);
}

function rosterAfterIsClaimedByAuth(studentId) {
  return existsAfter(/databases/$(database)/documents/student_roster/$(studentId))
         && getAfter(/databases/$(database)/documents/student_roster/$(studentId)).data.isClaimed == true
         && getAfter(/databases/$(database)/documents/student_roster/$(studentId)).data.linkedUid == request.auth.uid
         && getAfter(/databases/$(database)/documents/student_roster/$(studentId)).data.linkedEmail == request.auth.token.email;
}

function userAfterPointsToRoster(studentId) {
  return existsAfter(/databases/$(database)/documents/users/$(request.auth.uid))
         && getAfter(/databases/$(database)/documents/users/$(request.auth.uid)).data.uid == request.auth.uid
         && getAfter(/databases/$(database)/documents/users/$(request.auth.uid)).data.email == request.auth.token.email
         && getAfter(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'student'
         && getAfter(/databases/$(database)/documents/users/$(request.auth.uid)).data.studentId == studentId;
}

function teacherStudentKeys() {
  return ['name', 'session_id', 'class_id', 'updated_at', 'updated_by'];
}

function studentSelfKeys() {
  return ['self_session_id', 'self_class_id', 'self_updated_at'];
}

function isValidTeacherStudentFields() {
  return (!('name' in request.resource.data)
          || (request.resource.data.name is string
              && request.resource.data.name.size() > 0
              && request.resource.data.name.size() <= 20))
         && (!('session_id' in request.resource.data)
             || (request.resource.data.session_id is string
                 && request.resource.data.session_id.size() <= 50))
         && (!('class_id' in request.resource.data)
             || (request.resource.data.class_id is string
                 && request.resource.data.class_id.size() <= 20))
         && (!('updated_at' in request.resource.data)
             || request.resource.data.updated_at == request.time)
         && (!('updated_by' in request.resource.data)
             || request.resource.data.updated_by == request.auth.token.email);
}

function isValidSelfClass() {
  return (!('self_session_id' in request.resource.data)
          || (request.resource.data.self_session_id is string
              && request.resource.data.self_session_id.size() <= 50))
         && (!('self_class_id' in request.resource.data)
             || (request.resource.data.self_class_id is string
                 && request.resource.data.self_class_id.size() <= 20))
         && (!('self_updated_at' in request.resource.data)
             || request.resource.data.self_updated_at == request.time);
}

function isValidLessonSettings() {
  return request.resource.data.keys().hasOnly([
           'lessonId', 'date', 'classId', 'unit', 'activity', 'activityOptions', 'coreQuestion',
           'goalOptions', 'methodOptions', 'feedbackMode', 'feedbackOptions',
           'resultOptions', 'nextTryOptions', 'selFocus', 'inputEnabled',
           'shareDashboardEnabled', 'recordType', 'updated_at', 'updated_by'
         ])
         && (!('lessonId' in request.resource.data) || isShortString(request.resource.data.lessonId, 80))
         && (!('date' in request.resource.data) || isShortString(request.resource.data.date, 30))
         && (!('classId' in request.resource.data) || isShortString(request.resource.data.classId, 30))
         && (!('unit' in request.resource.data) || isShortString(request.resource.data.unit, 80))
         && (!('activity' in request.resource.data) || isShortString(request.resource.data.activity, 80))
         && (!('activityOptions' in request.resource.data) || isSmallList(request.resource.data.activityOptions, 50))
         && (!('coreQuestion' in request.resource.data) || isShortString(request.resource.data.coreQuestion, 500))
         && (!('goalOptions' in request.resource.data) || isSmallList(request.resource.data.goalOptions, 50))
         && (!('methodOptions' in request.resource.data) || isSmallList(request.resource.data.methodOptions, 50))
         && (!('feedbackOptions' in request.resource.data) || isSmallList(request.resource.data.feedbackOptions, 50))
         && (!('resultOptions' in request.resource.data) || isSmallList(request.resource.data.resultOptions, 50))
         && (!('nextTryOptions' in request.resource.data) || isSmallList(request.resource.data.nextTryOptions, 50))
         && (!('selFocus' in request.resource.data) || isSmallList(request.resource.data.selFocus, 50))
         && (!('feedbackMode' in request.resource.data) || request.resource.data.feedbackMode in ['received', 'given'])
         && (!('inputEnabled' in request.resource.data) || request.resource.data.inputEnabled is bool)
         && (!('shareDashboardEnabled' in request.resource.data) || request.resource.data.shareDashboardEnabled is bool)
         && (!('recordType' in request.resource.data) || request.resource.data.recordType in ['quick', 'deep'])
         && (!('updated_at' in request.resource.data) || request.resource.data.updated_at == request.time)
         && (!('updated_by' in request.resource.data) || request.resource.data.updated_by == request.auth.token.email);
}

function isValidStudentResponse() {
  return request.resource.data.keys().hasOnly([
           'submitted_at', 'session_id', 'class_id', 'student_id', 'student_name',
           'record_no', 'record_no_value', 'activity_code', 'activity_today',
           'question_source', 'question_qid', 'inquiry_question',
           'method_codes', 'method_labels', 'evidence_result', 'next_try',
           'agency_score', 'sel_competency_codes', 'sel_competency_labels',
           'sel_competency_code', 'sel_competency_label',
           'record_type', 'feedback_mode', 'peer_feedback', 'reflection_text', 'app_version',
           'roster_student_id', 'roster_class_name', 'roster_student_number', 'roster_display_name',
           'deep_question_evolution', 'deep_question_evolution_label',
           'deep_unit_growth_code', 'deep_unit_growth_label',
           'deep_next_unit_code', 'deep_next_unit_label', 'deep_unit'
         ])
         && request.resource.data.keys().hasAll([
           'submitted_at', 'session_id', 'class_id', 'student_id', 'student_name',
           'activity_code', 'inquiry_question', 'method_codes', 'evidence_result', 'next_try',
           'agency_score', 'sel_competency_codes', 'app_version'
         ])
         && request.resource.data.student_id == request.auth.uid
         && isShortString(request.resource.data.session_id, 50)
         && isShortString(request.resource.data.class_id, 20)
         && isLongString(request.resource.data.student_name, 50)
         && (!('record_no' in request.resource.data) || isShortString(request.resource.data.record_no, 30))
         && (!('record_no_value' in request.resource.data) || (request.resource.data.record_no_value is int && request.resource.data.record_no_value >= 1 && request.resource.data.record_no_value <= 300))
         && isSafeOptionToken(request.resource.data.activity_code)
         && (!('activity_today' in request.resource.data) || isLongString(request.resource.data.activity_today, 200))
         && (!('question_source' in request.resource.data) || request.resource.data.question_source in ['bank', 'previous', 'direct', 'manual', 'custom', 'deep', ''])
         && (!('question_qid' in request.resource.data) || isShortString(request.resource.data.question_qid, 80))
         && isLongString(request.resource.data.inquiry_question, 1000)
         && isSafeCodeList1To5(request.resource.data.method_codes)
         && (!('method_labels' in request.resource.data) || isSafeStringList(request.resource.data.method_labels, 10, 200))
         && isLongString(request.resource.data.evidence_result, 2000)
         && isLongString(request.resource.data.next_try, 1000)
         && request.resource.data.agency_score is number
         && request.resource.data.agency_score >= 1
         && request.resource.data.agency_score <= 5
         && isSafeCodeList1To3(request.resource.data.sel_competency_codes)
         && (!('sel_competency_labels' in request.resource.data) || isSafeStringList(request.resource.data.sel_competency_labels, 10, 200))
         && (!('sel_competency_code' in request.resource.data) || isSafeText(request.resource.data.sel_competency_code, 200))
         && (!('sel_competency_label' in request.resource.data) || isSafeText(request.resource.data.sel_competency_label, 200))
         && (!('record_type' in request.resource.data) || request.resource.data.record_type in ['quick', 'deep'])
         && (!('feedback_mode' in request.resource.data) || request.resource.data.feedback_mode in ['', 'received', 'given'])
         && (!('peer_feedback' in request.resource.data) || isShortString(request.resource.data.peer_feedback, 500))
         && (!('reflection_text' in request.resource.data) || isShortString(request.resource.data.reflection_text, 2000))
         && (!('deep_question_evolution' in request.resource.data) || isShortString(request.resource.data.deep_question_evolution, 80))
         && (!('deep_question_evolution_label' in request.resource.data) || isShortString(request.resource.data.deep_question_evolution_label, 200))
         && (!('deep_unit_growth_code' in request.resource.data) || isShortString(request.resource.data.deep_unit_growth_code, 80))
         && (!('deep_unit_growth_label' in request.resource.data) || isShortString(request.resource.data.deep_unit_growth_label, 200))
         && (!('deep_next_unit_code' in request.resource.data) || isShortString(request.resource.data.deep_next_unit_code, 80))
         && (!('deep_next_unit_label' in request.resource.data) || isShortString(request.resource.data.deep_next_unit_label, 200))
         && (!('deep_unit' in request.resource.data) || isShortString(request.resource.data.deep_unit, 80))
         && isShortString(request.resource.data.app_version, 100);
}

function isEmailLike(value) {
  return value is string
         && value.size() > 0
         && value.size() <= 254
         && value.matches('^[^@]+@[^@]+[.][^@]+$')
         && !value.matches('.*[<>].*');
}

function isNullableEmail(value) {
  return value == null || isEmailLike(value);
}

function isSafeText(value, max) {
  return value is string
         && value.size() > 0
         && value.size() <= max
         && !value.matches('.*[<>].*')
         && !value.matches('^[=+@-].*');
}

function isNullableSafeText(value, max) {
  return value == null || isSafeText(value, max);
}

function isSafeOptionToken(value) {
  return value is string
         && value.size() > 0
         && value.size() <= 80
         && !value.matches('.*[<>].*')
         && !value.matches('^[=+@-].*');
}

function isSafeCodeList1To5(value) {
  return value is list
         && value.size() >= 1
         && value.size() <= 5
         && isSafeOptionToken(value[0])
         && (value.size() < 2 || isSafeOptionToken(value[1]))
         && (value.size() < 3 || isSafeOptionToken(value[2]))
         && (value.size() < 4 || isSafeOptionToken(value[3]))
         && (value.size() < 5 || isSafeOptionToken(value[4]));
}

function isSafeCodeList1To3(value) {
  return value is list
         && value.size() >= 1
         && value.size() <= 3
         && isSafeOptionToken(value[0])
         && (value.size() < 2 || isSafeOptionToken(value[1]))
         && (value.size() < 3 || isSafeOptionToken(value[2]));
}

function isSafeStringList(value, maxItems, maxText) {
  return value is list
         && value.size() <= maxItems
         && (value.size() < 1 || isSafeText(value[0], maxText))
         && (value.size() < 2 || isSafeText(value[1], maxText))
         && (value.size() < 3 || isSafeText(value[2], maxText))
         && (value.size() < 4 || isSafeText(value[3], maxText))
         && (value.size() < 5 || isSafeText(value[4], maxText))
         && (value.size() < 6 || isSafeText(value[5], maxText))
         && (value.size() < 7 || isSafeText(value[6], maxText))
         && (value.size() < 8 || isSafeText(value[7], maxText))
         && (value.size() < 9 || isSafeText(value[8], maxText))
         && (value.size() < 10 || isSafeText(value[9], maxText));
}

function isShortString(value, max) {
  return value is string && value.size() <= max;
}

function isLongString(value, max) {
  return value is string && value.size() > 0 && value.size() <= max;
}

function isSmallList(value, max) {
  return value is list && value.size() <= max;
}
